⸻

🎨 ОБНОВИ CSS

.bike {
  position: absolute;
  bottom: 20px;
  left: -220px;
  animation: ride 6s linear infinite;
}

/* колёса */
.wheel {
  fill: none;
  stroke: white;
  stroke-width: 4;
  animation: spin 0.7s linear infinite;
  transform-origin: center;
}

/* движение */
@keyframes ride {
  0% { left: -220px; }
  100% { left: 100%; }
}

/* вращение */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}


